# ─── Iceberg Lakehouse — environment template ────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is git-ignored — never commit real credentials.

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=lakehouse
MINIO_ENDPOINT=http://minio:9000

# ── PostgreSQL (Iceberg catalog backend) ─────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=iceberg_catalog
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=changeme

# ── Iceberg catalog ───────────────────────────────────────────────────────────
CATALOG_NAME=local
CATALOG_URI=postgresql+psycopg2://iceberg:changeme@postgres:5432/iceberg_catalog
CATALOG_WAREHOUSE=s3://lakehouse/warehouse

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Weather fetcher (Open-Meteo — no API key required) ───────────────────────
# Hyderabad, India — change for your city
OPEN_METEO_LATITUDE=17.38
OPEN_METEO_LONGITUDE=78.47
FETCH_CRON=*/5 * * * *

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
